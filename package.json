{
  "name": "root",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": {
    "packages": [
      "packages/dicebear",
      "packages/@dicebear/*",
      "apps/*"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:scripts": "node --test 'scripts/tests/*.test.js'",
    "prepare-publish": "node scripts/version.mjs",
    "prettier": "prettier --write \"{packages,apps}/**/*.{js,ts,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "tar": "^7.5.7"
  }
}
