{
  "name": "root",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/dicebear",
      "packages/@dicebear/*",
      "apps/*"
    ]
  },
  "scripts": {
    "build": "lerna run build",
    "test": "lerna run test",
    "prepare-publish": "lerna version --force-publish --exact",
    "prettier": "prettier --write \"{packages,apps}/**/*.{js,ts,json,md}\""
  },
  "devDependencies": {
    "lerna": "^9.0.3",
    "prettier": "^3.8.1"
  },
  "overrides": {
    "tar": "^7.5.7"
  }
}
