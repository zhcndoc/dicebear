{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "jsx": "preserve",
    "types": [],
    "paths": {
      "@theme/*": [
        "./.vitepress/theme/*"
      ],
      "@playground/*": [
        "./.vitepress/theme/components/playground/*"
      ]
    },
    "skipLibCheck": true
  },
  "include": [
    "env.d.ts",
    ".vitepress/**/*"
  ],
  "exclude": [
    ".vitepress/cache",
    ".vitepress/dist"
  ]
}
