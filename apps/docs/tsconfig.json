{
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "types": [],
    "paths": {
      "@theme/*": [".vitepress/theme/*"],
      "@playground/*": [".vitepress/theme/components/playground/*"]
    }
  },
  "include": ["env.d.ts", ".vitepress/**/*"]
}
